{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["develop"],
  "labels": ["dependencies"],
  "prHourlyLimit": 2,
  "automerge": false,
  "packageRules": [
    {
      "matchManagers": ["sbt"],
      "groupName": "scala dependencies"
    }
  ],
  "npm": {
    "enabled": true
  }
}